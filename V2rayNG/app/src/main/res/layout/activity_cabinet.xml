<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vsm_toolbar"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/vsm_surface2"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/vsm_toolbar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/vsm_toolbar"
                android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
                app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/restore_hero_bg"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/vsm_cabinet_eyebrow"
                android:textAllCaps="true"
                android:textColor="@color/vsm_mint"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCabinetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/vsm_cabinet_title"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCabinetIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="1sp"
                android:text="@string/vsm_cabinet_intro"
                android:textColor="#E6EAF3"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvCabinetStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/restore_status_info_bg"
                android:lineSpacingExtra="1sp"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:textColor="@color/vsm_link"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pbCabinet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/vsm_mint" />

            <LinearLayout
                android:id="@+id/layoutCabinetLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/restore_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCabinetLoginTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/vsm_cabinet_login_title"
                    android:textColor="@color/vsm_restore_card_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCabinetLoginBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/vsm_cabinet_login_body"
                    android:textColor="@color/vsm_restore_card_body"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCabinetEmailLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/vsm_restore_email_label"
                    android:textColor="@color/vsm_restore_card_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCabinetEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/restore_input_bg"
                    android:hint="@string/vsm_restore_email_hint"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingTop="13dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="13dp"
                    android:textColor="@color/vsm_restore_input_text"
                    android:textColorHint="@color/vsm_restore_input_hint"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnCabinetSendCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/vsm_pay_btn"
                    android:minHeight="48dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:text="@string/vsm_restore_send_code"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <LinearLayout
                    android:id="@+id/layoutCabinetVerify"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/vsm_restore_code_label"
                        android:textColor="@color/vsm_restore_card_title"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etCabinetCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/restore_input_bg"
                        android:gravity="center"
                        android:hint="@string/vsm_cabinet_code_hint"
                        android:inputType="number"
                        android:letterSpacing="0.2"
                        android:maxLength="6"
                        android:maxLines="1"
                        android:paddingStart="14dp"
                        android:paddingTop="13dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="13dp"
                        android:textColor="@color/vsm_restore_input_text"
                        android:textColorHint="@color/vsm_restore_input_hint"
                        android:textSize="20sp" />

                    <Button
                        android:id="@+id/btnCabinetVerify"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:backgroundTint="@color/vsm_sub_ok"
                        android:minHeight="48dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/vsm_cabinet_enter"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/btnCabinetResendCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="6dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="6dp"
                        android:paddingBottom="4dp"
                        android:text="@string/vsm_restore_resend_code"
                        android:textColor="@color/vsm_link"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCabinetContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/restore_card_bg"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvCabinetAccount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/vsm_restore_card_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCabinetSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="1sp"
                        android:textColor="@color/vsm_restore_card_body"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnCabinetRenew"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:backgroundTint="@color/vsm_pay_btn"
                        android:minHeight="48dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/vsm_cabinet_renew"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btnCabinetRefresh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/vsm_restore_card_body"
                        android:minHeight="48dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/vsm_cabinet_refresh"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/restore_card_bg"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/vsm_cabinet_members_title"
                        android:textColor="@color/vsm_restore_card_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/llCabinetMembers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />

                    <Button
                        android:id="@+id/btnCabinetAddMember"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:backgroundTint="@color/vsm_sub_ok"
                        android:minHeight="48dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/vsm_cabinet_add_member"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btnCabinetDistribute"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/vsm_restore_card_body"
                        android:minHeight="48dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:text="@string/vsm_cabinet_distribute"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnCabinetLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/vsm_sub_urgent"
                    android:minHeight="48dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:text="@string/vsm_cabinet_logout"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
