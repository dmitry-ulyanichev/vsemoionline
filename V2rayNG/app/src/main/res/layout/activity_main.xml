<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/vsm_toolbar"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- ── Toolbar ─────────────────────────────────── -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/vsm_toolbar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/vsm_toolbar"
                android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
                app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- ── Subscription row (42dp) ─────────────────── -->
        <LinearLayout
            android:id="@+id/row_subscription"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:paddingStart="@dimen/padding_spacing_dp16"
            android:paddingEnd="@dimen/padding_spacing_dp16"
            android:gravity="center_vertical"
            android:background="@color/vsm_surface">

            <TextView
                android:id="@+id/tv_sub_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vsm_sub_label"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary" />

            <TextView
                android:id="@+id/tv_sub_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/vsm_sub_free"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/vsm_sub_free" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_sub_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/vsm_cabinet_link"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/vsm_link"
                android:paddingStart="9dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/pill_link_bg"
                android:drawableEnd="@drawable/ic_chevron_right_small"
                android:drawablePadding="2dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/divider_fade" />

        <!-- ── Server row (46dp) ────────────────────────── -->
        <LinearLayout
            android:id="@+id/row_server"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="@dimen/padding_spacing_dp16"
            android:paddingEnd="@dimen/padding_spacing_dp16"
            android:gravity="center_vertical"
            android:background="@color/vsm_surface"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_server_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vsm_server_label"
                android:textSize="12sp"
                android:textColor="?android:textColorHint"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_server_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_server_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textColor="?android:textColorPrimary" />

            <ImageView
                android:id="@+id/tv_server_arrow"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/vsm_border" />

        <!-- ── VPN area (flexible height) ──────────────── -->
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/vsm_surface2"
            android:clipChildren="false"
            android:minHeight="120dp">

            <!-- Progress bar docked at top -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_waiting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:indeterminate="true"
                android:visibility="invisible"
                app:indicatorColor="@color/vsm_mint" />

            <!-- FAB + status label grouped so they move together -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:clipChildren="false">

                <!-- FrameLayout keeps halo behind FAB -->
                <FrameLayout
                    android:id="@+id/fab_touch_target"
                    android:layout_width="116dp"
                    android:layout_height="116dp"
                    android:clipChildren="false"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/fab_halo"
                        android:layout_width="116dp"
                        android:layout_height="116dp"
                        android:layout_gravity="center"
                        android:background="@drawable/fab_halo"
                        android:elevation="0dp"
                        android:alpha="0" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/tasker_start_service"
                        android:src="@drawable/ic_power"
                        android:visibility="visible"
                        app:fabCustomSize="88dp"
                        app:maxImageSize="40dp"
                        app:backgroundTint="@color/vsm_traffic_green"
                        app:tint="@android:color/white" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_vpn_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textSize="13sp"
                    android:letterSpacing="0.04"
                    android:textColor="?android:textColorSecondary"
                    android:text="@string/vpn_disconnected" />

            </LinearLayout>

            <!-- Hidden V2rayNG internals — kept for binding/adapter/ViewModel wiring -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:tabMode="scrollable"
                app:tabTextAppearance="@style/TabLayoutTextStyle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                android:scrollbars="vertical" />

            <LinearLayout
                android:id="@+id/layout_test"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_test_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_test_pending"
                    android:textAppearance="@style/TextAppearance.AppCompat.Small" />

            </LinearLayout>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <!-- ── Subscription management block ───────────── -->
        <LinearLayout
            android:id="@+id/layout_sub_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:background="@color/vsm_surface">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/vsm_border" />

            <!-- Header — always visible, tap to expand/collapse -->
            <LinearLayout
                android:id="@+id/layout_sub_header"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingEnd="@dimen/padding_spacing_dp16"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_sub_block_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/vsm_sub_block_title"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:textColor="?android:textColorHint" />

                <TextView
                    android:id="@+id/tv_sub_traffic_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/tv_sub_chevron"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="" />

            </LinearLayout>

            <!-- Collapsible body (VISIBLE = expanded by default) -->
            <LinearLayout
                android:id="@+id/layout_sub_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingEnd="@dimen/padding_spacing_dp16"
                android:paddingTop="6dp"
                android:paddingBottom="18dp"
                android:visibility="visible">

                <!-- Charts row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="4dp">

                    <!-- Traffic chart item -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginEnd="10dp">

                        <com.v2ray.ang.ui.DonutChartView
                            android:id="@+id/chart_traffic"
                            android:layout_width="96dp"
                            android:layout_height="96dp" />

                        <TextView
                            android:id="@+id/tv_chart_traffic_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/vsm_chart_remaining"
                            android:textSize="12sp"
                            android:textColor="?android:textColorSecondary" />

                    </LinearLayout>

                    <!-- Speed chart item -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginStart="10dp">

                        <com.v2ray.ang.ui.DonutChartView
                            android:id="@+id/chart_speed"
                            android:layout_width="96dp"
                            android:layout_height="96dp" />

                        <TextView
                            android:id="@+id/tv_chart_speed_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/vsm_chart_speed"
                            android:textSize="12sp"
                            android:textColor="?android:textColorSecondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Comparison table — free user only, GONE for paid -->
                <LinearLayout
                    android:id="@+id/layout_cmp_table"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:orientation="vertical"
                    android:background="@color/vsm_border"
                    android:padding="1dp"
                    android:visibility="visible">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/vsm_surface2">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_col_free"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="?android:textColorHint" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_col_paid"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/vsm_link" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/vsm_border" />

                    <!-- Скорость row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/vsm_surface">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_row_speed"
                            android:textSize="12sp"
                            android:textColor="?android:textColorSecondary" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_free_speed"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="?android:textColorHint" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_paid_speed"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/vsm_link" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/vsm_border" />

                    <!-- Трафик row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/vsm_surface">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_row_traffic"
                            android:textSize="12sp"
                            android:textColor="?android:textColorSecondary" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:id="@+id/tv_cmp_free_traffic"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_free_traffic"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="?android:textColorHint" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:id="@+id/tv_cmp_paid_traffic"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_paid_traffic"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/vsm_link" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/vsm_border" />

                    <!-- Серверы row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@color/vsm_surface">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_row_servers"
                            android:textSize="12sp"
                            android:textColor="?android:textColorSecondary" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_free_servers"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:textColor="?android:textColorHint" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/vsm_border" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="6dp"
                            android:text="@string/vsm_cmp_paid_servers"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/vsm_link" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Оплатить подписку — free user, always visible initially -->
                <!-- FrameLayout owns gradient + shadow; clipToOutline clips button to rounded corners -->
                <FrameLayout
                    android:id="@+id/btn_pay_container"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/btn_pay_bg"
                    android:elevation="6dp"
                    android:clipToOutline="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/vsm_btn_pay"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@null"
                        app:cornerRadius="0dp"
                        app:backgroundTint="@android:color/transparent"
                        app:rippleColor="#40FFFFFF"
                        app:strokeWidth="0dp" />

                </FrameLayout>

                <!-- ❤ Подключите родных и близких — paid, days > 3, initially GONE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_family"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="11dp"
                    android:text="@string/vsm_btn_family"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    app:cornerRadius="10dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#46367D32"
                    app:backgroundTint="@android:color/transparent"
                    android:visibility="gone" />

                <!-- Share card — regular members only, initially GONE -->
                <LinearLayout
                    android:id="@+id/layout_share_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:orientation="vertical"
                    android:background="@drawable/vsm_share_card_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone">

                    <!-- Label row: icon + text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:src="@drawable/ic_vsm_share"
                            android:layout_marginEnd="7dp" />

                        <TextView
                            android:id="@+id/tv_share_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/vsm_share_label"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"
                            android:letterSpacing="-0.01" />

                    </LinearLayout>

                    <!-- Share row: URL preview + copy button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:background="@drawable/vsm_share_row_bg"
                        android:clipToOutline="true">

                        <TextView
                            android:id="@+id/tv_share_url"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="…/get"
                            android:textSize="12sp"
                            android:textColor="@color/vsm_sub_free"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:gravity="center_vertical"
                            android:paddingStart="11dp"
                            android:paddingEnd="4dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_share_copy"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="@string/vsm_share_copy"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            app:backgroundTint="#56AB7B"
                            app:cornerRadius="0dp"
                            app:strokeWidth="0dp"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:letterSpacing="0.01" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Продлить подписку — paid, days ≤ 3, initially GONE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_renew"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="11dp"
                    android:text="@string/vsm_btn_renew"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    app:cornerRadius="10dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#38E65100"
                    app:backgroundTint="@android:color/transparent"
                    android:visibility="gone" />

                <!-- Activation success flash (shown briefly after code accepted, then auto-hides) -->
                <TextView
                    android:id="@+id/tv_code_success"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:text="@string/vsm_code_activated"
                    android:textSize="13sp"
                    android:textColor="@color/vsm_mint"
                    android:gravity="center"
                    android:visibility="gone" />

                <!-- Activation section: shown for free users and paid users with ≤3 days left -->
                <LinearLayout
                    android:id="@+id/layout_activation_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:text="@string/vsm_label_enter_code"
                    android:textSize="13sp"
                    android:textColor="?android:textColorSecondary" />

                <!-- Activation code row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- 8 single-char code fields with hyphen separator -->
                    <EditText
                        android:id="@+id/et_code_1"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_2"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_3"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_4"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:text="–"
                        android:textSize="18sp"
                        android:textColor="?android:textColorSecondary"
                        android:gravity="center" />

                    <EditText
                        android:id="@+id/et_code_5"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_6"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_7"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionNext"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <EditText
                        android:id="@+id/et_code_8"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/code_field_bg"
                        android:gravity="center"
                        android:inputType="textCapCharacters|textNoSuggestions"
                        android:maxLength="1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:imeOptions="actionDone"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:hint="×"
                        android:textColorHint="#80AAAAAA" />

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/btn_submit_bg"
                        android:elevation="4dp"
                        android:clipToOutline="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_code_submit"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:enabled="false"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:stateListAnimator="@null"
                            app:icon="@drawable/ic_arrow_right"
                            app:iconSize="22dp"
                            app:iconPadding="0dp"
                            app:iconGravity="textStart"
                            app:iconTint="@android:color/white"
                            app:cornerRadius="0dp"
                            app:backgroundTint="@android:color/transparent"
                            app:rippleColor="#40FFFFFF"
                            app:strokeWidth="0dp" />

                    </FrameLayout>

                </LinearLayout>

                </LinearLayout> <!-- /layout_activation_section -->

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/vsm_surface"
        app:headerLayout="@layout/nav_header"
        app:itemIconTint="@color/vsm_link"
        app:itemTextColor="?android:textColorPrimary"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
